<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <!-- Background card that will be dynamically tinted -->
    <ImageView
        android:id="@+id/widget_background_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/widget_bg"
        android:scaleType="fitXY"
        android:contentDescription="Widget Background" />

    <!-- Widget content container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Header Row (Date and Streak) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/widget_date_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Friday, Jun 12"
                android:textColor="@color/widget_text_secondary"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/widget_streak_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔥 0 day streak"
                android:textColor="@color/streak_fire"
                android:textSize="12sp"
                android:textStyle="bold"
                android:maxLines="1" />
        </LinearLayout>

        <!-- Content Area -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="8dp">

            <!-- STATE A: Prompt to Write Today's Entry (Shown if not filled) -->
            <LinearLayout
                android:id="@+id/widget_prompt_layout"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="visible">

                <TextView
                    android:id="@+id/widget_prompt_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="How was your day?"
                    android:textColor="@color/widget_text_title"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/widget_prompt_subtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Write today's entry to protect your streak."
                    android:textColor="@color/widget_text_secondary"
                    android:textSize="12sp"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/widget_prompt_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/widget_chip_bg"
                    android:paddingLeft="10dp"
                    android:paddingRight="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:text="+ Write entry"
                    android:textColor="@color/widget_primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- STATE B: Display Today's Entry (Shown if already written) -->
            <LinearLayout
                android:id="@+id/widget_entry_layout"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/widget_entry_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Today's Entry Title"
                    android:textColor="@color/widget_text_title"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/widget_entry_note"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginTop="4dp"
                    android:text="Today's journal entry note content goes here..."
                    android:textColor="@color/widget_text_body"
                    android:textSize="12sp"
                    android:maxLines="2"
                    android:ellipsize="end" />

                <!-- Bottom row for stars and adjective chip -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="6dp">

                    <TextView
                        android:id="@+id/widget_entry_rating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="★★★★★"
                        android:textColor="@color/streak_fire"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/widget_entry_adjective"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="8dp"
                        android:background="@drawable/widget_chip_bg"
                        android:paddingLeft="6dp"
                        android:paddingRight="6dp"
                        android:paddingTop="2dp"
                        android:paddingBottom="2dp"
                        android:text="Productive"
                        android:textColor="@color/widget_text_secondary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end" />
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>
</FrameLayout>
